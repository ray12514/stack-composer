# TODO(scaffold): Review GPU target variants for AMD/NVIDIA before use.
# Rendered by {{ renderer_identity.name }} {{ renderer_identity.version }}
spack:
  view: {{ view_root }}
  include:
{% for scope in scopes %}
    - {{ scope }}
{% endfor %}
  specs:
{% for spec in specs %}
    - {{ spec }}{% if lane.gpu_arch.startswith("gfx") %} amdgpu_target={{ lane.gpu_arch }}{% elif lane.gpu_arch.startswith("sm_") %} cuda_arch={{ lane.gpu_arch[3:] }}{% endif %}
{% endfor %}
